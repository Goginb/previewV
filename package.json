{
  "name": "previewv",
  "version": "0.1.0",
  "description": "Infinite canvas video reference board",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "clean": "node -e \"try{require('fs').rmSync('out',{recursive:true,force:true})}catch(e){}\"",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder build --win"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.3"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-rnd": "^10.4.1",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.nfamf.previewv",
    "productName": "PreviewV",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "previewv",
        "name": "PreviewV project",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null,
      "signAndEditExecutable": false
    }
  }
}
